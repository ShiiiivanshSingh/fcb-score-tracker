{
  "manifest_version": 3,
  "name": "FC Barcelona Live Tracker",
  "version": "1.1",
  "description": "Real-time FC Barcelona scores, fixtures, results — with live match notifications.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://api.football-data.org/*",
    "https://www.thesportsdb.com/*"
  ]
}